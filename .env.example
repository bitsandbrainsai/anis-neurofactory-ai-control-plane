# =====================================================
# CORE ENVIRONMENT
# =====================================================

NODE_ENV=production
TIMEZONE=UTC


# =====================================================
# n8n CONFIGURATION
# =====================================================

N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Used for webhook URLs
N8N_BASE_URL=https://your-n8n-instance.com

# Optional (recommended for production)
N8N_ENCRYPTION_KEY=your_encryption_key_here


# =====================================================
# GOOGLE APIs
# =====================================================

# Google OAuth (used by Gmail, Drive, Sheets nodes)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Optional if using service account
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=


# =====================================================
# GOOGLE DRIVE & SHEETS IDS
# =====================================================

GOOGLE_DRIVE_RAW_FOLDER_ID=
GOOGLE_DRIVE_CLEAN_FOLDER_ID=
GOOGLE_DRIVE_GOLD_FOLDER_ID=
GOOGLE_DRIVE_REPORT_FOLDER_ID=

GOOGLE_SHEETS_CONTROL_SPREADSHEET_ID=
GOOGLE_SHEETS_DATA_CATALOG_SHEET_ID=
GOOGLE_SHEETS_EVENT_LOG_SHEET_ID=
GOOGLE_SHEETS_TASKS_INBOX_SHEET_ID=


# =====================================================
# GPT / OPENAI
# =====================================================

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1-mini


# =====================================================
# ANIS HUB WEBHOOK
# =====================================================

ANIS_WEBHOOK_SECRET=your_webhook_secret
ANIS_ALLOWED_AGENTS=ingest,clean,analyze,report


# =====================================================
# SERVERLESS OCR (VERCEL)
# =====================================================

OCR_API_URL=https://your-vercel-app.vercel.app/api/ocr-summarize
OCR_TIMEOUT_MS=60000


# =====================================================
# LOGGING
# =====================================================

LOG_LEVEL=info
